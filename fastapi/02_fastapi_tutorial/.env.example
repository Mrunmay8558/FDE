# Copy this file to .env and fill in the real values for local development.
# These variables are read with os.getenv(...) after load_dotenv() is called.

# DOMAIN and BASE_URL:
#   These are common backend settings for building links, callbacks, or email URLs.
#   In this tutorial they are kept as standard examples, but they are not used directly yet.
DOMAIN=localhost:8000
BASE_URL=http://localhost:8000

# MongoDB
# MONGODB_URL:
#   Used in core/database/database.py as the single MongoDB connection string
#   for this tutorial project.
MONGODB_URL=mongodb://localhost:27017

# DATABASE_NAME:
#   Used in core/database/database.py to decide which MongoDB database to connect to.
DATABASE_NAME=fastapi_tutorial

# JWT
# secret:
#   Used in commons/auth.py to sign and verify JWT tokens.
secret=your_super_secret_jwt_key_change_this_in_production

# algorithm:
#   Used in commons/auth.py as the JWT signing algorithm.
algorithm=HS256

# Gmail SMTP (for sending emails)
# gmail_user:
#   Used in core/utils/email/email_helper.py as the sender email address.
gmail_user=your_gmail@gmail.com

# gmail_app_password:
#   Used in core/utils/email/email_helper.py as the SMTP password for Gmail.
gmail_app_password=your_gmail_app_password

# App branding (used in email templates)
# logo_url:
#   Used in core/utils/email/email_template_generator.py to render a logo in email headers.
logo_url=https://yourdomain.com/logo.png

# company_name:
#   Used in core/utils/email/email_template_generator.py in subjects, headers, and footers.
company_name=MyApp

# support_email:
#   Used in core/utils/email/email_template_generator.py for the footer and support contact text.
support_email=support@yourdomain.com
